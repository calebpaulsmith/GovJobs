# Copy to .env (gitignored). Used by the SvelteKit app.

# Mapbox public token. Without it, the basemap falls back to OpenStreetMap raster
# tiles. For production, restrict the token to thegrandpipeline.com and *.pages.dev
# in the Mapbox dashboard.
VITE_MAPBOX_TOKEN=

# Optional: override the data bundle path (default: /data, served from static/).
# VITE_DATA_BASE=/data
