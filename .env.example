# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- USAJOBS API credentials ---
# Get a key at https://developer.usajobs.gov/
# The User-Agent header must be your contact email.
USAJOBS_USER_AGENT=your_email@example.com
USAJOBS_AUTHORIZATION_KEY=your_usajobs_api_key_here

# --- Local paths ---
DATABASE_PATH=data/federal_jobs.sqlite
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed

# --- Reconnaissance / download thresholds ---
# A dataset is "huge" (and triggers a focused/staged/sample mode) if any of these
# are exceeded. Tune in config.py if your machine is bigger or smaller than typical.
MAX_FULL_DOWNLOAD_GB=5
MAX_DATABASE_GB=10
MAX_FULL_DOWNLOAD_ROWS=5000000
MAX_IMPORT_HOURS=8

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/app.log

# --- Public map reference-data inputs ---
# These are optional. Unset values make refresh_public_map_data.py skip that
# ingest step and leave it for a later manual/backfill run.
PUBLIC_MAP_STATE_GEOJSON=data/external/states.geojson
PUBLIC_MAP_COUNTY_GEOJSON=data/external/counties.geojson
PUBLIC_MAP_CBSA_GEOJSON=data/external/cbsas.geojson
PUBLIC_MAP_LOCALITY_DEFS_CSV=data/external/opm_locality_definitions_2026.csv
PUBLIC_MAP_LOCALITY_PAY_CSV=data/external/opm_locality_pay_2026.csv
PUBLIC_MAP_LOCALITY_YEAR=2026
PUBLIC_MAP_GS_PAY_CSVS=data/external/opm_gs_pay_2026.csv
PUBLIC_MAP_OTHER_PAY_PLANS=
PUBLIC_MAP_BEA_RPP_CSV=data/external/bea_rpp_2024.csv
