# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- USAJOBS API credentials ---
# Get a key at https://developer.usajobs.gov/
# The User-Agent header must be your contact email.
USAJOBS_USER_AGENT=your_email@example.com
USAJOBS_AUTHORIZATION_KEY=your_usajobs_api_key_here

# --- Local paths ---
DATABASE_PATH=data/federal_jobs.sqlite
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed

# --- Reconnaissance / download thresholds ---
# A dataset is "huge" (and triggers a focused/staged/sample mode) if any of these
# are exceeded. Tune in config.py if your machine is bigger or smaller than typical.
MAX_FULL_DOWNLOAD_GB=5
MAX_DATABASE_GB=10
MAX_FULL_DOWNLOAD_ROWS=5000000
MAX_IMPORT_HOURS=8

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=data/app.log
